-include= ~../cnf/resources/bnd/bundle.props
bVersion=1.0


Bundle-Name: io.openliberty.http.tracing.internal
Bundle-SymbolicName: io.openliberty.http.tracing.internal
Bundle-Description: Distributed Tracing for HTTP Requests

WS-TraceGroup: OPENTRACING

-dsannotations: \
    io.openliberty.http.tracing.internal.HttpTracingServletContainerInitializer

Import-Package: \
  *

-buildpath: \
    com.ibm.ws.logging;version=latest, \
    com.ibm.ws.org.osgi.annotation.versioning;version=latest, \
    com.ibm.wsspi.org.osgi.service.component;version=latest, \
    com.ibm.wsspi.org.osgi.core;version=latest, \
    com.ibm.wsspi.org.osgi.service.component.annotations;version=latest, \
    com.ibm.websphere.org.osgi.service.cm;version=latest, \
    com.ibm.websphere.javaee.servlet.4.0;version=latest, \
    io.openliberty.io.opentracing.opentracing-api.0.33.0;version=latest, \
    io.openliberty.io.opentracing.opentracing-util.0.33.0;version=latest
